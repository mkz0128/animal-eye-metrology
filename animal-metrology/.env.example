# =============================================================================
# Animal Eye Metrology API - Environment Variables
# =============================================================================
# 使用方式：複製此檔案並重新命名為 .env
#   cp .env.example .env
# 然後根據你的環境調整數值。
# 注意：.env 已加入 .gitignore，請勿將真實設定值提交至版本控制。
# =============================================================================

# --- 基本設定 ---
PROJECT_NAME="Animal Eye Metrology API"
VERSION="1.0.0"

# 開啟後會輸出額外的 debug 資訊，正式部署建議設為 False
DEBUG_MODE=True

# --- 硬體設定 ---
# 推論裝置，有 NVIDIA GPU 請使用 cuda，否則改為 cpu（速度會明顯較慢）
DEVICE="cuda"

# --- 模型設定 ---
# Grounding DINO 模型版本
# - grounding-dino-tiny：較輕量，適合 VRAM < 4GB 的環境，但準確率較低
# - grounding-dino-base：建議使用，準確率較佳，需要約 4GB+ VRAM
GROUNDING_DINO_MODEL="IDEA-Research/grounding-dino-base"

# SAM 2 模型版本（首次啟動會自動從 Meta 官方下載 checkpoint）
SAM2_MODEL="facebook/sam2.1-hiera-tiny"

# --- 偵測門檻 ---
# 物件偵測信心門檻，數值越低越容易偵測到目標，但誤偵測也會增加
BOX_THRESHOLD=0.15

# 文字匹配門檻，控制文字提示與偵測結果的匹配嚴格程度
TEXT_THRESHOLD=0.15

# --- 輸出路徑 ---
# 視覺化結果的儲存路徑
SAVE_VISUALIZATION_PATH="./outputs/"

# =============================================================================
# 進階偵測參數
# 以下參數目前直接定義於 src/main.py 中，如需調整請直接修改該檔案。
# =============================================================================

# 貓隻偵測
#   CAT_THRESHOLD = 0.15       # 貓隻偵測信心門檻
#   CAT_NMS_IOU = 0.4          # NMS IoU 門檻（重疊超過此值視為重複偵測）
#   CAT_CONTAIN_RATIO = 0.7    # 包含框過濾比例（被包含超過此比例視為重複）

# 眼睛偵測
#   EYE_THRESHOLD = 0.10       # 眼睛偵測信心門檻
#   EYE_NMS_IOU = 0.3          # 眼睛 NMS IoU 門檻
#   EYE_MAX_SIZE_RATIO = 0.2   # 眼睛框最大尺寸，不得超過裁切區域的 20%
#   PAIR_MIN_DIST_RATIO = 0.05 # 兩眼最小距離，不得小於裁切寬度的 5%
#   PAIR_MAX_DIST_RATIO = 0.35 # 兩眼最大距離，不得超過裁切寬度的 35%
#   PAIR_MAX_AREA_RATIO = 4.0  # 兩眼面積比例上限，差異超過 4 倍視為誤配對
#   EYE_UPSCALE_TARGET = 512   # 裁切區域放大目標尺寸（px），提升小圖偵測準確率